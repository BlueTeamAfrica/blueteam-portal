rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // Plan id safe for planPermissions/{id} path: only string/number scalars (object/map plan fields would break path resolution).
    function safeBillingPlanSegment(v) {
      return v is string
        ? (v.size() > 0 ? v : null)
        : v is int
        ? string(v)
        : v is float
        ? string(v)
        : null;
    }

    // Subscription plan when subscription is a map with plan; otherwise null (never chain .plan off missing/non-map subscription).
    function tenantSubscriptionPlanId(tenant) {
      return ('subscription' in tenant.data)
        && tenant.data.subscription is map
        && ('plan' in tenant.data.subscription)
        && tenant.data.subscription.plan != null
        ? safeBillingPlanSegment(tenant.data.subscription.plan)
        : null;
    }

    // Helper function to get tenant billing plan ID (mirrors portal getBillingPlanIdFromTenant).
    function getBillingPlanId(tenantId) {
      let tenant = get(/databases/$(db)/documents/tenants/$(tenantId));
      let subPlan = tenantSubscriptionPlanId(tenant);
      let topPlan = ('plan' in tenant.data) ? safeBillingPlanSegment(tenant.data.plan) : null;
      let billId = ('billingPlanId' in tenant.data) ? safeBillingPlanSegment(tenant.data.billingPlanId) : null;
      return subPlan != null
        ? subPlan
        : topPlan != null
        ? topPlan
        : billId != null
        ? billId
        : 'starter';
    }

    // Helper function to get plan permissions
    function getPlanPermissions(tenantId) {
      let billingPlanId = getBillingPlanId(tenantId);
      let permissions = get(/databases/$(db)/documents/tenants/$(tenantId)/planPermissions/$(billingPlanId));
      return permissions.data;
    }

    // Invoice create: allow when planPermissions doc is missing OR canInvoices is not explicitly false.
    // (Avoids get() on a missing planPermissions doc, which would deny all creates.)
    function tenantPlanAllowsInvoiceCreate(tenantId) {
      let billingPlanId = getBillingPlanId(tenantId);
      let permPath = /databases/$(db)/documents/tenants/$(tenantId)/planPermissions/$(billingPlanId);
      return !exists(permPath) || get(permPath).data.canInvoices != false;
    }

    // Helper function to check if user has access to tenant
    function hasTenantAccess(tenantId) {
      return request.auth != null
        && exists(/databases/$(db)/documents/userTenants/$(request.auth.uid + "_" + tenantId));
    }

    // Explicit helper for tenant subcollection read: user has a userTenants mapping for this tenant
    function isTenantUser(tenantId) {
      return request.auth != null
        && exists(/databases/$(db)/documents/userTenants/$(request.auth.uid + "_" + tenantId));
    }

    // Client users: tenantId and clientId stored in users/{uid}, no userTenants required
    function isClientWithTenantAccess(tenantId) {
      return request.auth != null
        && exists(/databases/$(db)/documents/users/$(request.auth.uid))
        && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
        && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role == "client";
    }

    function getClientIdFromUser() {
      return get(/databases/$(db)/documents/users/$(request.auth.uid)).data.clientId;
    }

    // Helper function to check if user has access (backward compatibility)
    function hasTenantAccessLegacy() {
      return request.auth != null
        && exists(/databases/$(db)/documents/userTenants/$(request.auth.uid + "_blueteam"));
    }

    // Role from userTenants/{uid}_{tenantId}; use exists() before get() so a missing map doc does not fail rule evaluation.
    function getUserRole(tenantId) {
      let userTenantId = request.auth.uid + "_" + tenantId;
      let utPath = /databases/$(db)/documents/userTenants/$(userTenantId);
      return exists(utPath) ? get(utPath).data.role : null;
    }

    // Helper function to check if user is admin or owner
    function isAdminOrOwner(tenantId) {
      let role = getUserRole(tenantId);
      return role == "admin" || role == "owner";
    }

    // Helper function to check if user is client
    function isClient(tenantId) {
      let role = getUserRole(tenantId);
      return role == "client";
    }

    // Users collection: each user can read their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /userTenants/{mapId} {
      // Allow read if document ID matches userId_tenantId or userId_blueteam format
      allow read, list: if request.auth != null
        && (
          // Deterministic mapping IDs (preferred)
          mapId == request.auth.uid + "_blueteam"
          || mapId.matches(request.auth.uid + "_" + ".*")
          // Legacy/random doc IDs: allow only if the doc belongs to the authed user
          || resource.data.userId == request.auth.uid
        );
    }

    match /tenants/{tenantId} {
      allow read: if hasTenantAccess(tenantId) || hasTenantAccessLegacy()
        || (request.auth != null && exists(/databases/$(db)/documents/users/$(request.auth.uid))
            && get(/databases/$(db)/documents/users/$(request.auth.uid)).data.tenantId == tenantId);
      
      // Plan permissions subcollection
      match /planPermissions/{planId} {
        allow read: if hasTenantAccess(tenantId) || hasTenantAccessLegacy();
      }

      // Explicit: tenants/{tenantId}/clients/{clientId}
      match /clients/{clientId} {
        allow read, list: if isTenantUser(tenantId) || (isClientWithTenantAccess(tenantId) && clientId == getClientIdFromUser());
        allow write: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);
      }

      // Explicit: tenants/{tenantId}/projects/{projectId}
      match /projects/{projectId} {
        allow read, list: if isTenantUser(tenantId) || (isClientWithTenantAccess(tenantId) && resource.data.clientId == getClientIdFromUser());
        allow write: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);
      }

      // Services collection - enforce canServices flag and role
      match /services/{serviceId} {
        // Admin/owner full access for tenant services
        allow create, read, list, update, delete: if isAdminOrOwner(tenantId);

        // Clients can read/list only their own services
        allow read, list: if isClientWithTenantAccess(tenantId)
          && resource.data.clientId == getClientIdFromUser();
      }

      // Explicit: tenants/{tenantId}/invoices/{invoiceId}
      match /invoices/{invoiceId} {
        allow read, list: if isTenantUser(tenantId) || (isClientWithTenantAccess(tenantId) && resource.data.clientId == getClientIdFromUser());
        allow update, delete: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);
        allow create: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId)
          && tenantPlanAllowsInvoiceCreate(tenantId);
      }

      // Explicit: tenants/{tenantId}/subscriptions/{subId}
      match /subscriptions/{subId} {
        allow read, list: if isTenantUser(tenantId) || (isClientWithTenantAccess(tenantId) && resource.data.clientId == getClientIdFromUser());
        allow write: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);
      }

      // Explicit: tenants/{tenantId}/tickets/{ticketId}
      match /tickets/{ticketId} {
        // Admins/owners can see all tenant tickets; clients can only see their own
        allow read, list: if isTenantUser(tenantId)
          || (isClientWithTenantAccess(tenantId) && resource.data.clientId == getClientIdFromUser());

        // Admin/owner can create any ticket; clients can only create tickets for themselves
        allow create: if ((hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId))
          || (isClientWithTenantAccess(tenantId)
              && request.resource.data.clientId == getClientIdFromUser());

        // Only admin/owner can update/delete tickets (e.g., status changes)
        allow update, delete: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);

        // Replies subcollection: tenants/{tenantId}/tickets/{ticketId}/replies/{replyId}
        match /replies/{replyId} {
          allow read, list: if isTenantUser(tenantId)
            || (isClientWithTenantAccess(tenantId)
                && get(/databases/$(db)/documents/tenants/$(tenantId)/tickets/$(ticketId)).data.clientId == getClientIdFromUser());

          allow create: if ((hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId))
            || (isClientWithTenantAccess(tenantId)
                && get(/databases/$(db)/documents/tenants/$(tenantId)/tickets/$(ticketId)).data.clientId == getClientIdFromUser());

          allow update, delete: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);
        }
      }

      match /payments/{paymentId} {
        allow read: if hasTenantAccess(tenantId) || hasTenantAccessLegacy();
        allow write: if (hasTenantAccess(tenantId) || hasTenantAccessLegacy()) && isAdminOrOwner(tenantId);
      }
    }
  }
}
